    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction normalizeIdArray(arr) {\n  if (!Array.isArray(arr)) return [];\n\n  return arr\n    .map(v => Number(v))\n    .filter(v => Number.isFinite(v));\n}\n\nfunction normalizeUsernameArray(value) {\n  const raw = String(value ?? '');\n\n  return raw\n    .split(/\\r?\\n/)\n    .map(s => s.trim())\n    .filter(Boolean)\n    .map(s => (s.startsWith('@') ? s : `@${s}`));\n}\n\nfunction arraysEqualAsSets(a, b) {\n  const aa = [...new Set(a)].sort((x, y) => x - y);\n  const bb = [...new Set(b)].sort((x, y) => x - y);\n\n  if (aa.length !== bb.length) return false;\n\n  for (let i = 0; i < aa.length; i++) {\n    if (aa[i] !== bb[i]) return false;\n  }\n\n  return true;\n}\n\nfunction buildPairs(ids, usernames, source = null) {\n  const len = Math.min(ids.length, usernames.length);\n  const pairs = [];\n\n  for (let i = 0; i < len; i++) {\n    const pair = {\n      chat_id: ids[i],\n      chat_username: usernames[i],\n    };\n\n    if (source) {\n      pair.source = source;\n    }\n\n    pairs.push(pair);\n  }\n\n  return pairs;\n}\n\nconst result = [];\n\nfor (const item of items) {\n  const row = item.json;\n\n  const regexpIds = normalizeIdArray(row.chat_id_regexp);\n  const regexpUsernames = normalizeUsernameArray(row.chat_usernames_regexp);\n\n  const llmIds = normalizeIdArray(row.chat_id_llm);\n  const llmUsernames = normalizeUsernameArray(row.chat_usernames_llm);\n\n  const sendTo = row.send_to ?? null;\n\n  const idsAreEqual = arraysEqualAsSets(regexpIds, llmIds);\n\n  if (idsAreEqual) {\n    const pairs = buildPairs(regexpIds, regexpUsernames, sendTo, 'merged');\n\n    for (const pair of pairs) {\n      result.push({ json: pair });\n    }\n  } else {\n    const regexpPairs = buildPairs(regexpIds, regexpUsernames, sendTo, 'regexp');\n    const llmPairs = buildPairs(llmIds, llmUsernames, sendTo, 'llm');\n\n    for (const pair of [...regexpPairs, ...llmPairs]) {\n      result.push({ json: pair });\n    }\n  }\n}\n\nreturn result;"
      },
