      "parameters": {
        "jsCode": "// n8n Code Node — классификация сообщений по regexp из первого item\n\nconst allItems = $input.all();\n\nif (!allItems.length) {\n  throw new Error('Нет входных элементов');\n}\n\n// --------------------------------------------------\n// 1) Берём regexp из первого item\n// --------------------------------------------------\nconst first = allItems[0].json;\nlet regexText = first.regexp ?? first.RegExp ?? first.regex ?? first.patterns;\n\nif (!regexText) {\n  throw new Error('Первый элемент должен содержать поле regexp');\n}\n\nregexText = String(regexText).trim();\n\n// Если строка пришла в кавычках целиком\nif (\n  (regexText.startsWith('\"') && regexText.endsWith('\"')) ||\n  (regexText.startsWith(\"'\") && regexText.endsWith(\"'\"))\n) {\n  regexText = regexText.slice(1, -1);\n}\n\n// Убираем хвост \";\"\nregexText = regexText.replace(/;\\s*$/, '').trim();\n\n// Убираем возможную обёртку вида: const x = ...\nregexText = regexText.replace(/^\\s*(const|let|var)\\s+\\w+\\s*=\\s*/i, '').trim();\n\n// Ожидаем объект вида { key: /.../gi, key2: /.../gi }\nregexText = regexText.replace(/^\\s*\\{/, '').replace(/\\}\\s*$/, '').trim();\n\n// --------------------------------------------------\n// 2) Парсим пары key: /pattern/flags\n// --------------------------------------------------\nconst regexMap = {};\nconst pairRe = /(\\w+)\\s*:\\s*\\/((?:\\\\\\/|[^\\/])+)\\/([gimsuyd]*)/g;\n\nlet match;\nwhile ((match = pairRe.exec(regexText)) !== null) {\n  const key = match[1];\n  const pattern = match[2];\n  const flags = match[3] || '';\n\n  try {\n    regexMap[key] = new RegExp(pattern, flags);\n  } catch (e) {\n    throw new Error(`Ошибка в RegExp для \"${key}\": ${e.message}`);\n  }\n}\n\nif (!Object.keys(regexMap).length) {\n  throw new Error('Не удалось распарсить regexp-объект: не найдено ни одной пары key:/.../flags');\n}\n\n// --------------------------------------------------\n// 3) Функция классификации одного текста\n// --------------------------------------------------\nfunction classifyText(textRaw) {\n  const text = String(textRaw ?? '');\n\n  const matchedCategories = [];\n  const matchedTexts = {};\n\n  for (const [key, re] of Object.entries(regexMap)) {\n    // Новый экземпляр, чтобы избежать проблем с lastIndex у /g\n    const localRe = new RegExp(re.source, re.flags);\n    const hits = text.match(localRe);\n\n    if (hits && hits.length) {\n      matchedCategories.push(key);\n\n      // убираем дубли и ограничиваем количество\n      matchedTexts[key] = [...new Set(hits)].slice(0, 10);\n    }\n  }\n\n  return {\n    regexp_relevant: matchedCategories.length > 0 ? 1 : 0,\n    matched_categories: matchedCategories,\n    matched_texts: matchedTexts,\n  };\n}\n\n// --------------------------------------------------\n// 4) Обрабатываем items со 2-го по последний\n// --------------------------------------------------\nconst results = [];\n\nfor (let i = 1; i < allItems.length; i++) {\n  const item = allItems[i].json;\n  const text = item.text ?? '';\n\n  const classified = classifyText(text);\n\n  results.push({\n    json: {\n      ...item,\n      regexp_relevant: classified.regexp_relevant,\n      matched_categories: classified.matched_categories,\n      matched_texts: classified.matched_texts,\n    },\n  });\n}\n\nreturn results;"
      },
