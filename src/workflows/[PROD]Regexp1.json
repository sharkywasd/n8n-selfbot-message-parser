    },
    {
      "parameters": {
        "jsCode": "// n8n Code Node — RegExp classifier for text_positive/text_negative\nconst allItems = $input.all();\nif (!allItems.length) throw new Error('Нет входных элементов');\n\n// 1) Берём строку с regexp-объектом (во входе: \"regexp\")\nconst first = allItems[0].json;\nlet regexText = first.regexp ?? first.RegExp;\n\nif (!regexText) {\n  throw new Error('Первый элемент должен содержать поле regexp (строка с объектом регулярных выражений)');\n}\n\nregexText = String(regexText).trim();\n\n// Иногда приходит как строка с кавычками вокруг: \"{ ... };\"\nif (\n  (regexText.startsWith('\"') && regexText.endsWith('\"')) ||\n  (regexText.startsWith(\"'\") && regexText.endsWith(\"'\"))\n) {\n  regexText = regexText.slice(1, -1);\n}\n\n// Убираем хвост \";\"\nregexText = regexText.replace(/;\\s*$/, '').trim();\n\n// Убираем обёртку вида: const X = ...;\nregexText = regexText.replace(/^\\s*(const|let|var)\\s+\\w+\\s*=\\s*/i, '').trim();\n\n// Теперь ожидаем: { key: /.../gi, ... }\nregexText = regexText.replace(/^\\s*\\{/, '').replace(/\\}\\s*$/, '').trim();\n\n// 2) Парсим пары key: /pattern/flags\nconst regexMap = {};\nconst pairRe = /(\\w+)\\s*:\\s*\\/([\\s\\S]*?)\\/([gimyus]*)/g;\n\nlet m;\nwhile ((m = pairRe.exec(regexText)) !== null) {\n  const key = m[1];\n  const pattern = m[2];\n  const flags = m[3] || '';\n  try {\n    regexMap[key] = new RegExp(pattern, flags);\n  } catch (e) {\n    throw new Error(`Ошибка в RegExp для \"${key}\": ${e.message}`);\n  }\n}\n\nif (!Object.keys(regexMap).length) {\n  throw new Error('Не удалось распарсить regexp-объект: нет ни одной пары key:/.../flags');\n}\n\n// 3) Хелпер классификации для одного текста\nfunction classifyText(textRaw) {\n  const text = String(textRaw ?? '').trim();\n  const lowerText = text.toLowerCase();\n\n  const matchedCategories = [];\n  const matchedSnippets = {};\n\n  for (const [key, re] of Object.entries(regexMap)) {\n    // чтобы избежать проблем с lastIndex у /g — используем новый RegExp на каждый прогон\n    const localRe = new RegExp(re.source, re.flags);\n    const hits = lowerText.match(localRe);\n    if (hits && hits.length) {\n      matchedCategories.push(key);\n      matchedSnippets[key] = hits.slice(0, 5);\n    }\n  }\n\n  const has = (k) => (matchedCategories.includes(k) ? 1 : 0);\n\n  return {\n    text,\n    regexp_relevant: matchedCategories.length > 0 ? 1 : 0,\n    classification: {\n      matched: matchedCategories.length > 0,\n      categories: matchedCategories,\n      matched_texts: matchedSnippets,\n      has_any_match: matchedCategories.length > 0 ? 1 : 0,\n\n      is_transcription: has('transcription'),\n      is_diarization: has('diarization'),\n      is_subtitles: has('subtitles'),\n      is_summary: has('summary'),\n      is_sentiment: has('sentiment'),\n      is_noiseHandling: has('noiseHandling'),\n      is_fileFormats: has('fileFormats'),\n    },\n  };\n}\n\n// 4) Обрабатываем элементы 2..N\nconst results = [];\n\nfor (let i = 1; i < allItems.length; i++) {\n  const item = allItems[i].json;\n\n  const pos = classifyText(item.text_positive);\n  const neg = classifyText(item.text_negative);\n\n  results.push({\n    json: {\n      row_number: item.row_number,\n      ID: item.ID,\n\n      text_positive: pos.text,\n      text_negative: neg.text,\n\n      regexp_relevant_positive: pos.regexp_relevant,\n      regexp_relevant_negative: neg.regexp_relevant,\n\n      classification_positive: pos.classification,\n      classification_negative: neg.classification,\n    },\n  });\n}\n\nreturn results;"
      },
