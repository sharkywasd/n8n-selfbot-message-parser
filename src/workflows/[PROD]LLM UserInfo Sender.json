    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map((item) => {\n  const row = item.json;\n\n  const chatId = Number(row.chat_id);\n  const messageId = Number(row.message_id);\n\n  if (!Number.isFinite(chatId) || !Number.isFinite(messageId)) {\n    return {\n      json: {\n        error: 'Missing or invalid chat_id/message_id',\n        original_data: row,\n      },\n    };\n  }\n\n  const query = `\n    UPDATE telegram_messages\n    SET\n      tg_sent = $1,\n      updated_at = CURRENT_TIMESTAMP\n    WHERE\n      chat_id = $2\n      AND message_id = $3\n    RETURNING\n      id,\n      chat_id,\n      user_id,\n      message_id,\n      tg_sent,\n      updated_at;\n  `;\n\n  return {\n    json: {\n      query,\n      params: [1, chatId, messageId],\n      action: 'mark_as_sent',\n      update_data: {\n        chat_id: chatId,\n        message_id: messageId,\n        tg_sent: 1,\n      },\n    },\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2800,
        480
      ],
