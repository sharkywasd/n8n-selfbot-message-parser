    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nif (items.length < 2) {\n  throw new Error('Ожидается 2 item: первый с chat_id, второй с data');\n}\n\nconst currentChatId = Number(items[0]?.json?.chat_id);\n\nif (!Number.isFinite(currentChatId)) {\n  throw new Error('В первом item отсутствует корректный chat_id');\n}\n\nconst data = items[1]?.json?.data;\n\nif (!Array.isArray(data)) {\n  throw new Error('Во втором item должен быть массив data');\n}\n\nconst matched = data.find(row => Number(row.chat_id) === currentChatId);\n\nif (!matched) {\n  return [\n    {\n      json: {\n        chat_id: currentChatId,\n        found: 0,\n      },\n    },\n  ];\n}\n\nreturn [\n  {\n    json: {\n      ...matched,\n      found: 1,\n    },\n  },\n];"
      },
