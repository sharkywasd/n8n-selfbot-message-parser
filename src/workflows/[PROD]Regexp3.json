    },
    {
      "parameters": {
        "jsCode": "// n8n Code Node — RegExp classifier for text_positive/text_negative\nconst allItems = $input.all();\n\nif (!allItems.length) {\n  throw new Error('Нет входных элементов');\n}\n\n// --------------------------------------------------\n// 1) Берём regexp-объект из первого item\n// --------------------------------------------------\nconst first = allItems[0].json;\nlet regexText = first.regexp ?? first.RegExp ?? first.regex ?? first.patterns;\n\nif (!regexText) {\n  throw new Error('Первый элемент должен содержать поле regexp');\n}\n\nregexText = String(regexText).trim();\n\n// Если строка пришла целиком в кавычках\nif (\n  (regexText.startsWith('\"') && regexText.endsWith('\"')) ||\n  (regexText.startsWith(\"'\") && regexText.endsWith(\"'\"))\n) {\n  regexText = regexText.slice(1, -1);\n}\n\n// Убираем хвост \";\"\nregexText = regexText.replace(/;\\s*$/, '').trim();\n\n// Убираем обёртку вида const x = ...\nregexText = regexText.replace(/^\\s*(const|let|var)\\s+\\w+\\s*=\\s*/i, '').trim();\n\n// Убираем внешние {}\nregexText = regexText.replace(/^\\s*\\{/, '').replace(/\\}\\s*$/, '').trim();\n\n// --------------------------------------------------\n// 2) Парсим пары key: /pattern/flags\n// --------------------------------------------------\nconst regexMap = {};\n\n// Поддерживает экранированные \\/ внутри regex\nconst pairRe = /(\\w+)\\s*:\\s*\\/((?:\\\\\\/|[^\\/])*)\\/([gimsuyd]*)/g;\n\nlet match;\nwhile ((match = pairRe.exec(regexText)) !== null) {\n  const key = match[1];\n  const pattern = match[2];\n  const flags = match[3] || '';\n\n  try {\n    regexMap[key] = new RegExp(pattern, flags);\n  } catch (e) {\n    throw new Error(`Ошибка в RegExp для \"${key}\": ${e.message}`);\n  }\n}\n\nconst regexKeys = Object.keys(regexMap);\n\nif (!regexKeys.length) {\n  throw new Error('Не удалось распарсить regexp-объект: не найдено ни одной пары key:/.../flags');\n}\n\n// --------------------------------------------------\n// 3) Хелпер классификации одного текста\n// --------------------------------------------------\nfunction classifyText(textRaw) {\n  const text = textRaw == null ? null : String(textRaw).trim();\n\n  // Если текста нет\n  if (!text) {\n    const emptyFlags = {};\n    for (const key of regexKeys) {\n      emptyFlags[`is_${key}`] = 0;\n    }\n\n    return {\n      text: null,\n      regexp_relevant: 0,\n      classification: {\n        matched: false,\n        categories: [],\n        matched_texts: {},\n        has_any_match: 0,\n        ...emptyFlags,\n      },\n    };\n  }\n\n  const matchedCategories = [];\n  const matchedTexts = {};\n\n  for (const [key, re] of Object.entries(regexMap)) {\n    // Новый экземпляр regex на каждый прогон — чтобы не было проблем с /g\n    const localRe = new RegExp(re.source, re.flags);\n    const hits = text.match(localRe);\n\n    if (hits && hits.length) {\n      matchedCategories.push(key);\n      matchedTexts[key] = [...new Set(hits)].slice(0, 10);\n    }\n  }\n\n  const dynamicFlags = {};\n  for (const key of regexKeys) {\n    dynamicFlags[`is_${key}`] = matchedCategories.includes(key) ? 1 : 0;\n  }\n\n  return {\n    text,\n    regexp_relevant: matchedCategories.length > 0 ? 1 : 0,\n    classification: {\n      matched: matchedCategories.length > 0,\n      categories: matchedCategories,\n      matched_texts: matchedTexts,\n      has_any_match: matchedCategories.length > 0 ? 1 : 0,\n      ...dynamicFlags,\n    },\n  };\n}\n\n// --------------------------------------------------\n// 4) Обрабатываем элементы 2..N\n// --------------------------------------------------\nconst results = [];\n\nfor (let i = 1; i < allItems.length; i++) {\n  const item = allItems[i].json;\n\n  const pos = classifyText(item.text_positive);\n  const neg = classifyText(item.text_negative);\n\n  results.push({\n    json: {\n      row_number: item.row_number ?? null,\n      ID: item.ID ?? item.id ?? null,\n\n      text_positive: pos.text,\n      text_negative: neg.text,\n\n      regexp_relevant_positive: pos.regexp_relevant,\n      regexp_relevant_negative: neg.regexp_relevant,\n\n      classification_positive: pos.classification,\n      classification_negative: neg.classification,\n    },\n  });\n}\n\nreturn results;"
      },
