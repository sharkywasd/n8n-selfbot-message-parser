    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const data = item.json;\n\n  if (data.chat_id === undefined || data.message_id === undefined) {\n    return {\n      json: {\n        error: 'Missing chat_id or message_id',\n        data,\n      }\n    };\n  }\n\n  const { _debug, ...dataWithoutDebug } = data;\n\n  const regexpRelevant = Number(dataWithoutDebug.regexp_relevant ?? 0) ? 1 : 0;\n\n  const matchedCategories = Array.isArray(dataWithoutDebug.matched_categories)\n    ? dataWithoutDebug.matched_categories\n    : [];\n\n  const matchedTexts =\n    dataWithoutDebug.matched_texts &&\n    typeof dataWithoutDebug.matched_texts === 'object' &&\n    !Array.isArray(dataWithoutDebug.matched_texts)\n      ? dataWithoutDebug.matched_texts\n      : {};\n\n  const query = `\n    UPDATE telegram_messages\n    SET \n      regexp_processed = $1,\n      regexp_relevant = $2,\n      regexp_matched_categories = $3::jsonb,\n      regexp_matched_texts = $4::jsonb,\n      updated_at = CURRENT_TIMESTAMP\n    WHERE \n      chat_id = $5\n      AND message_id = $6\n    RETURNING \n      id,\n      chat_id,\n      message_id,\n      regexp_processed,\n      regexp_relevant,\n      regexp_matched_categories,\n      regexp_matched_texts,\n      updated_at;\n  `;\n\n  const params = [\n    1,\n    regexpRelevant,\n    JSON.stringify(matchedCategories),\n    JSON.stringify(matchedTexts),\n    String(dataWithoutDebug.chat_id),\n    String(dataWithoutDebug.message_id),\n  ];\n\n  return {\n    json: {\n      query,\n      params,\n      update_data: {\n        chat_id: String(dataWithoutDebug.chat_id),\n        message_id: String(dataWithoutDebug.message_id),\n        regexp_processed: 1,\n        regexp_relevant: regexpRelevant,\n        regexp_matched_categories: matchedCategories,\n        regexp_matched_texts: matchedTexts,\n      },\n      action: 'update_regexp_status'\n    }\n  };\n});"
      },
